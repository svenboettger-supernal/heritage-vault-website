---
export interface Props {
  width?: "narrow" | "prose" | "default" | "wide";
  as?: string;
  class?: string;
}

const { width = "default", as: Tag = "div", class: className = "" } = Astro.props;

const widths: Record<NonNullable<Props["width"]>, string> = {
  narrow: "max-w-screen-narrow",
  prose: "max-w-screen-prose",
  default: "max-w-screen-default",
  wide: "max-w-screen-wide",
};
---

<Tag class:list={["mx-auto px-6 sm:px-8 lg:px-12", widths[width], className]}>
  <slot />
</Tag>
