---
export interface Props {
  items: Array<{ question: string; answer: string }>;
  schema?: boolean;
  /** Two-column heading + accordion layout (Wealth.com pattern). */
  layout?: "single" | "two-column";
  heading?: string;
  eyebrow?: string;
  subheading?: string;
  class?: string;
}

const {
  items,
  schema = true,
  layout = "single",
  heading,
  eyebrow,
  subheading,
  class: className = "",
} = Astro.props;

const faqSchema = schema
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: items.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    }
  : null;
---

<div class:list={[layout === "two-column" ? "grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-12 lg:gap-20" : "", className]}>
  {layout === "two-column" && heading && (
    <div class="md:sticky md:top-28 md:self-start">
      {eyebrow && <p class="eyebrow mb-6">{eyebrow}</p>}
      <h2 class="font-display text-display-md text-surface-navy leading-tight tracking-[-0.005em]">{heading}</h2>
      {subheading && <p class="mt-4 text-ink-muted">{subheading}</p>}
    </div>
  )}

  <div class="divide-y divide-[hsl(var(--rule))] border-y border-rule">
    {items.map((item, idx) => (
      <details class="group" name="vault-faq" open={idx === 0 && layout === "single"}>
        <summary class="flex items-start justify-between gap-6 py-6 cursor-pointer list-none">
          <span class="font-sans text-[1.0625rem] md:text-[1.125rem] font-medium leading-snug text-surface-navy text-balance">
            {item.question}
          </span>
          <span aria-hidden="true" class="shrink-0 mt-1 text-bronze group-open:rotate-45 transition-transform duration-fast">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
              <line x1="9" y1="3" x2="9" y2="15" />
              <line x1="3" y1="9" x2="15" y2="9" />
            </svg>
          </span>
        </summary>
        <div class="pb-6 pr-10 max-w-screen-prose">
          <p class="text-ink leading-relaxed text-[0.9375rem]">{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</div>

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
