---
/**
 * Product-screenshot placeholder. Renders a sized card with the brand's
 * atmospheric treatment so the page never has visible "broken image" gaps,
 * while clearly signaling that a real screenshot will replace it.
 *
 * Used everywhere the Heritage Vault platform UI would appear. Per brief §11.3,
 * production screenshots come from the live platform.
 */
export interface Props {
  /** Surface name being depicted, e.g. "Asset Schedule". */
  label: string;
  /** Optional short caption beneath the label. */
  caption?: string;
  aspect?: "landscape" | "wide" | "square" | "browser";
  class?: string;
}
const { label, caption, aspect = "browser", class: className = "" } = Astro.props;

const aspectClass: Record<NonNullable<Props["aspect"]>, string> = {
  landscape: "aspect-[16/10]",
  wide: "aspect-[21/9]",
  square: "aspect-square",
  browser: "aspect-[16/10]",
};
---

<figure
  class:list={[
    "relative overflow-hidden rounded-md border border-rule bg-surface-card shadow-elevated",
    aspectClass[aspect],
    className,
  ]}
  aria-label={`${label} screenshot placeholder`}
>
  {/* Browser chrome bar */}
  <div class="absolute top-0 inset-x-0 h-9 bg-surface-muted border-b border-rule flex items-center px-4 gap-2">
    <span aria-hidden="true" class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></span>
    <span aria-hidden="true" class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></span>
    <span aria-hidden="true" class="w-2.5 h-2.5 rounded-full bg-ink-muted/30"></span>
    <span class="ml-4 text-[11px] text-ink-muted font-mono">vault.heritagestrategies.com / {label.toLowerCase().replace(/\s+/g, "-")}</span>
  </div>

  {/* Atmospheric ground */}
  <div
    aria-hidden="true"
    class="absolute inset-0 pt-9"
    style="background: linear-gradient(180deg, hsl(214 47% 97%) 0%, hsl(214 47% 95%) 100%);"
  ></div>

  {/* Synthetic UI sketch — quiet grid of bars representing the surface */}
  <div class="absolute left-6 right-6 top-16 bottom-6 grid grid-cols-1 gap-3" aria-hidden="true">
    <div class="h-5 w-1/3 bg-surface-navy/85 rounded"></div>
    <div class="grid grid-cols-3 gap-3 mt-2 flex-1">
      <div class="bg-surface-card border border-rule rounded p-3 flex flex-col gap-2">
        <div class="h-2 w-1/2 bg-bronze/40 rounded"></div>
        <div class="h-3 w-3/4 bg-surface-navy/50 rounded"></div>
        <div class="h-2 w-2/3 bg-ink-muted/20 rounded"></div>
        <div class="h-2 w-1/2 bg-ink-muted/20 rounded"></div>
      </div>
      <div class="bg-surface-card border border-rule rounded p-3 flex flex-col gap-2">
        <div class="h-2 w-1/2 bg-bronze/40 rounded"></div>
        <div class="h-3 w-2/3 bg-surface-navy/50 rounded"></div>
        <div class="h-2 w-3/4 bg-ink-muted/20 rounded"></div>
        <div class="h-2 w-1/2 bg-ink-muted/20 rounded"></div>
      </div>
      <div class="bg-surface-card border border-rule rounded p-3 flex flex-col gap-2">
        <div class="h-2 w-1/2 bg-bronze/40 rounded"></div>
        <div class="h-3 w-1/2 bg-surface-navy/50 rounded"></div>
        <div class="h-2 w-2/3 bg-ink-muted/20 rounded"></div>
        <div class="h-2 w-3/4 bg-ink-muted/20 rounded"></div>
      </div>
    </div>
    <div class="space-y-2 mt-2">
      <div class="h-2 w-full bg-ink-muted/15 rounded"></div>
      <div class="h-2 w-11/12 bg-ink-muted/15 rounded"></div>
      <div class="h-2 w-10/12 bg-ink-muted/15 rounded"></div>
      <div class="h-2 w-9/12 bg-ink-muted/15 rounded"></div>
    </div>
  </div>

  {/* placeholder: production screenshot from live Heritage Vault platform per brief §11.3.
       The browser-chrome URL above already identifies the surface, so no figcaption is needed. */}
</figure>
