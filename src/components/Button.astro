---
export interface Props {
  variant?: "primary" | "secondary" | "ghost" | "on-dark" | "ghost-on-dark" | "text";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  disabled?: boolean;
  ariaLabel?: string;
  rel?: string;
  target?: string;
  /** Trailing arrow glyph (the Wealth.com pattern). */
  arrow?: boolean;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className = "",
  disabled = false,
  ariaLabel,
  rel,
  target,
  arrow = false,
} = Astro.props;

const sizeClass: Record<NonNullable<Props["size"]>, string> = {
  sm: "px-4 py-2 text-[12px]",
  md: "px-6 py-3 text-[13px]",
  lg: "px-8 py-4 text-[14px]",
};

const variantClass: Record<NonNullable<Props["variant"]>, string> = {
  primary:
    "bg-surface-navy text-ink-on-dark border border-surface-navy hover:bg-surface-dark hover:border-surface-dark",
  secondary:
    "bg-transparent text-surface-navy border border-surface-navy hover:bg-surface-navy hover:text-ink-on-dark",
  ghost:
    "bg-transparent text-ink border border-rule hover:border-surface-navy hover:text-surface-navy",
  "on-dark":
    "bg-ink-on-dark text-surface-navy border border-ink-on-dark hover:bg-surface-muted",
  "ghost-on-dark":
    "bg-transparent text-ink-on-dark border border-[hsl(35_26%_64%)] hover:bg-[hsl(35_26%_64%/0.14)]",
  text:
    "bg-transparent text-surface-navy hover:opacity-70 px-0 py-0 border-0 underline underline-offset-4 decoration-1",
};

const baseClass =
  "inline-flex items-center justify-center gap-2 rounded font-sans font-medium tracking-button uppercase no-underline transition-colors duration-fast disabled:opacity-50 disabled:cursor-not-allowed";

const classList = [
  baseClass,
  variantClass[variant],
  variant !== "text" && sizeClass[size],
  className,
];

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  rel={href ? rel : undefined}
  target={href ? target : undefined}
  aria-label={ariaLabel}
  aria-disabled={disabled ? "true" : undefined}
  class:list={classList}
>
  <slot />
  {arrow && (
    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M1 5h12M9 1l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
</Tag>
