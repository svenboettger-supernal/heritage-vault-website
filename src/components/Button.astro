---
/**
 * Button — direct port of the heritage-brand demo's `.btn` system.
 *
 * Five variants:
 *  - primary    (filled navy on light surfaces)
 *  - secondary  (navy-outlined on light surfaces)
 *  - ghost      (rule-bordered, navy text)
 *  - on-dark    (filled white + navy text, for placing on navy hero panels)
 *  - on-dark-secondary (transparent + white border + white text, for placing on navy)
 *
 * Per brand demo: padding 14px 26px, border-radius 3px, font-size 13px,
 * letter-spacing 0.14em, font-weight 500, uppercase, line-height 1.
 * Width is content-sized (w-fit + self-start) so flex parents never stretch.
 */
export interface Props {
  variant?: "primary" | "secondary" | "ghost" | "on-dark" | "on-dark-secondary";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  disabled?: boolean;
  ariaLabel?: string;
  rel?: string;
  target?: string;
  arrow?: boolean;
}

const {
  variant = "primary",
  href,
  type = "button",
  class: className = "",
  disabled = false,
  ariaLabel,
  rel,
  target,
  arrow = false,
} = Astro.props;

const variantClass: Record<NonNullable<Props["variant"]>, string> = {
  primary:
    "bg-surface-navy text-white border border-surface-navy hover:bg-surface-dark hover:border-surface-dark",
  secondary:
    "bg-transparent text-surface-navy border border-surface-navy hover:bg-surface-navy hover:text-white",
  ghost:
    "bg-transparent text-surface-navy border border-rule hover:bg-surface-muted",
  "on-dark":
    "bg-white text-surface-navy border border-white hover:bg-[#E4ECF7] hover:border-[#E4ECF7]",
  "on-dark-secondary":
    "bg-transparent text-white border border-white hover:bg-white/10",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={!href ? type : undefined}
  rel={href ? rel : undefined}
  target={href ? target : undefined}
  aria-label={ariaLabel}
  aria-disabled={disabled ? "true" : undefined}
  class:list={[
    "btn btn-vault",
    "inline-flex w-fit max-w-full self-start whitespace-nowrap items-center justify-center gap-2",
    "font-sans font-medium uppercase no-underline transition-colors duration-fast",
    "disabled:opacity-50 disabled:cursor-not-allowed",
    variantClass[variant],
    className,
  ]}
>
  <slot />
  {arrow && (
    <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M1 5h12M9 1l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}
</Tag>

<style>
  /* Direct port of brand-demo .btn — sizing identical for every variant. */
  .btn-vault {
    padding: 14px 26px;
    font-size: 13px;
    letter-spacing: 0.14em;
    line-height: 1;
    border-radius: 3px;
    border-bottom-width: 1px;
  }
</style>
