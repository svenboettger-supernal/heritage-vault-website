---
import Logo from "@components/Logo.astro";
import Button from "@components/Button.astro";

export interface Props {
  pathname?: string;
}
const { pathname = "/" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const nav = [
  { label: "Product", href: `${base}/product/` },
  { label: "For Firms", href: `${base}/firms/` },
  { label: "Security", href: `${base}/security/` },
  { label: "About", href: `${base}/about/` },
];

const isActive = (href: string) => {
  const trimmed = href.replace(base, "").replace(/\/$/, "");
  const current = pathname.replace(/\/$/, "");
  return trimmed && current.startsWith(trimmed);
};
---

<header class="sticky top-0 z-40 bg-surface-page/95 backdrop-blur supports-[backdrop-filter]:bg-surface-page/80">
  <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12 h-[72px] flex items-center justify-between gap-6">
    <Logo size="nav" href={`${base}/`} ariaLabel="Heritage Vault, home" />

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-10">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "no-underline text-[12px] font-medium tracking-nav uppercase transition-opacity duration-fast",
            isActive(item.href) ? "text-surface-navy opacity-100" : "text-ink hover:opacity-55",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <Button
        href={`${base}/request-access/`}
        variant="primary"
        class="hidden md:inline-flex btn-glow"
        arrow
      >
        Request access
      </Button>
      <button
        id="nav-toggle"
        type="button"
        aria-controls="nav-mobile"
        aria-expanded="false"
        class="lg:hidden p-2 -m-2 text-ink"
        aria-label="Open navigation"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="3" y1="6" x2="19" y2="6" />
          <line x1="3" y1="11" x2="19" y2="11" />
          <line x1="3" y1="16" x2="19" y2="16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="nav-mobile" hidden class="lg:hidden border-t border-rule bg-surface-card">
    <nav aria-label="Primary mobile" class="mx-auto max-w-screen-wide px-6 sm:px-8 py-4 flex flex-col gap-1">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "no-underline py-3 text-[14px] font-medium uppercase tracking-nav border-b border-rule last:border-b-0",
            isActive(item.href) ? "text-surface-navy" : "text-ink",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={`${base}/request-access/`}
        class="mt-3 inline-flex items-center justify-center bg-surface-navy text-ink-on-dark rounded px-5 py-3 font-medium text-[13px] tracking-button uppercase no-underline"
      >
        Request access
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    if (mobile) mobile.hidden = open;
  });
</script>
