---
import Logo from "@components/Logo.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();

const cols = [
  {
    title: "Product",
    links: [
      { label: "Overview", href: `${base}/product/` },
      { label: "Security", href: `${base}/security/` },
      { label: "Changelog", href: `#`, future: true },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "For Firms", href: `${base}/firms/` },
      { label: "About Heritage Vault", href: `${base}/about/` },
      { label: "Heritage Strategies (firm)", href: "https://heritagesllc.com/", external: true },
    ],
  },
  {
    title: "Get in touch",
    links: [
      { label: "Request access", href: `${base}/request-access/` },
      { label: "vault@getsupernal.ai", href: "mailto:vault@getsupernal.ai" },
    ],
  },
];
---

<footer class="bg-surface-page">
  <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12 py-20">
    <div class="grid gap-12 md:gap-16 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <Logo size="footer" />
        <p class="mt-6 max-w-xs text-sm leading-relaxed text-ink-muted">
          Heritage Vault is the estate-planning platform built by the firm that wrote the playbook.
        </p>
        <p class="mt-4 text-xs text-ink-muted">
          Heritage Vault is built by <a href="https://heritagesllc.com/" target="_blank" rel="noopener noreferrer" class="text-ink hover:opacity-70">Heritage Strategies LLC</a>, the multi-family office that has produced these plans by hand since 2009.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <p class="eyebrow mb-5">{col.title}</p>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class:list={[
                    "text-sm border-b-0 hover:opacity-70 transition-opacity duration-fast",
                    link.future && "text-ink-muted",
                  ]}
                >
                  {link.label}
                  {link.future && <span class="ml-2 inline-block align-middle text-[9px] tracking-[0.2em] uppercase text-ink-muted">Soon</span>}
                  {link.external && (
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.4" class="inline-block ml-1.5 align-baseline" aria-hidden="true">
                      <path d="M3 1h7v7M10 1L4 7M3 4v6h6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-rule flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-[12px] text-ink-muted">
        © {year} Heritage Strategies LLC. Heritage Vault is a product of Heritage Strategies.
      </p>
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[12px]">
        <li><a href={`${base}/privacy/`} class="text-ink-muted hover:text-ink border-b-0">Privacy</a></li>
        <li><a href={`${base}/terms/`} class="text-ink-muted hover:text-ink border-b-0">Terms</a></li>
        <li><a href={`${base}/accessibility/`} class="text-ink-muted hover:text-ink border-b-0">Accessibility</a></li>
      </ul>
    </div>
  </div>
</footer>
