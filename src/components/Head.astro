---
export interface Props {
  title: string;
  description: string;
  pathname?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, pathname = "/", ogImage, jsonLd } = Astro.props;

const siteName = "Heritage Vault";
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const canonical = new URL(`${base}${pathname}`, Astro.site).toString();
const ogImageUrl = new URL(`${base}/${ogImage ?? "og-image.svg"}`, Astro.site).toString();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Heritage Vault",
  applicationCategory: "BusinessApplication",
  applicationSubCategory: "Estate Planning Platform",
  operatingSystem: "Web",
  url: new URL(`${base}/`, Astro.site).toString(),
  description:
    "Heritage Vault is the estate-planning platform built by the firm that wrote the playbook. 20 to 40 hours of manual estate-plan production, reduced to under two. Built for the firms that serve ultra-high-net-worth families.",
  publisher: {
    "@type": "Organization",
    name: "Heritage Strategies LLC",
    url: "https://heritagesllc.com",
  },
  offers: {
    "@type": "Offer",
    availability: "https://schema.org/InStock",
    priceCurrency: "USD",
    price: "0",
    description: "Pilot license available by request.",
  },
};

const schemas = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#1E2A44" />
  <meta name="color-scheme" content="light" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:locale" content="en_US" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.svg`} />
  <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  {schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
