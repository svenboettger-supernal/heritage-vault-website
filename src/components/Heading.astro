---
export interface Props {
  size?: "display-xl" | "display-lg" | "display-md" | "display-sm" | "h3" | "h4" | "h5";
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  /** Toggle Source Serif 4 display vs Inter sans. Defaults to display for `display-*` sizes. */
  display?: boolean;
  class?: string;
  balance?: boolean;
}

const {
  size = "display-md",
  as,
  display,
  class: className = "",
  balance = true,
} = Astro.props;

const isDisplay = display ?? size.startsWith("display");
const Tag = (as ?? (size === "display-xl" ? "h1" : size.startsWith("display") ? "h2" : "h3")) as string;

const sizeClass: Record<NonNullable<Props["size"]>, string> = {
  "display-xl": "text-display-xl",
  "display-lg": "text-display-lg",
  "display-md": "text-display-md",
  "display-sm": "text-display-sm",
  h3: "text-xl font-medium leading-snug",
  h4: "text-lg font-medium leading-snug",
  h5: "text-base font-medium leading-snug",
};
---

<Tag
  class:list={[
    sizeClass[size],
    isDisplay
      ? "font-display font-normal tracking-[-0.005em]"
      : "font-sans",
    balance && "text-balance",
    className,
  ]}
  style={isDisplay ? 'font-variation-settings: "opsz" 60;' : undefined}
>
  <slot />
</Tag>
