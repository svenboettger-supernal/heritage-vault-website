---
/**
 * Request Access hero — parchment editorial, NOT a navy panel.
 * Approachable title plate per brief §7.6. No animated wave, no marketing chrome.
 * Reads like the cover of a private-bank correspondence, not a SaaS lead-capture.
 */
import Container from "@components/Container.astro";
---

<section
  class="bg-surface-page pt-16 md:pt-24 lg:pt-32 pb-12 md:pb-16 lg:pb-20"
  aria-labelledby="request-access-hero-title"
>
  <Container width="default">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-6 lg:gap-x-12">
      <div class="lg:col-span-10 lg:col-start-1">
        <p class="section-eyebrow">Request access</p>
        <h1
          id="request-access-hero-title"
          class="font-display font-normal text-display-xl text-surface-navy leading-[1.04] tracking-[-0.005em] text-balance"
          style='font-variation-settings: "opsz" 144;'
        >
          Speak with the Heritage Vault team.
        </h1>
      </div>

      <div class="lg:col-span-9 lg:col-start-1">
        <p class="mt-8 lg:mt-10 text-[19px] md:text-[21px] leading-[1.55] text-ink-muted text-pretty">
          Heritage Vault is a firm-level license. Tell us about your firm and a member of the team will respond within one business day. All inquiries are treated as confidential.
        </p>
      </div>
    </div>
  </Container>
</section>
