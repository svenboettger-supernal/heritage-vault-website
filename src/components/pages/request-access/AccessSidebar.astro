---
/**
 * AccessSidebar — three quiet info blocks supporting the form per brief §7.6.
 * Each block is a tinted card surface with a 1px bronze top border.
 * Quiet, supportive context. NOT a second set of CTAs.
 */

interface Step {
  n: string;
  text: string;
}

const steps: Step[] = [
  { n: "01", text: "We respond within one business day." },
  { n: "02", text: "A 30-minute confidential call to scope your engagement." },
  { n: "03", text: "If aligned, a pilot proposal within a week." },
];
---

<aside class="flex flex-col gap-6 lg:gap-8" aria-label="What to expect after submitting">
  {/* Block A — What happens next */}
  <section class="bg-surface-card border border-rule border-t-[1px] rounded p-7 md:p-8 relative">
    <span aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-bronze opacity-80"></span>
    <p class="eyebrow mb-5">What happens next</p>
    <ol class="space-y-4">
      {steps.map((step) => (
        <li class="flex gap-4 items-baseline">
          <span class="font-mono text-[12px] tracking-[0.1em] text-bronze uppercase shrink-0 mt-0.5">
            {step.n}
          </span>
          <span class="text-[15px] leading-[1.6] text-ink">{step.text}</span>
        </li>
      ))}
    </ol>
  </section>

  {/* Block B — Who responds */}
  <section class="bg-surface-card border border-rule rounded p-7 md:p-8 relative">
    <span aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-bronze opacity-80"></span>
    <p class="eyebrow mb-5">Who responds</p>
    <p class="text-[15px] leading-[1.65] text-ink">
      A member of the Heritage Vault team, typically the principal partner for your firm size. Not a sales rep, not an SDR.
    </p>
  </section>

  {/* Block C — Direct email */}
  <section class="bg-surface-card border border-rule rounded p-7 md:p-8 relative">
    <span aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-bronze opacity-80"></span>
    <p class="eyebrow mb-5">Or email directly</p>
    <p class="text-[16px] leading-[1.5]">
      <a
        href="mailto:vault@getsupernal.ai"
        class="font-mono text-[14px] tracking-[0.02em] text-surface-navy"
      >
        vault@getsupernal.ai
      </a>
    </p>
    <p class="mt-3 text-[14px] leading-[1.6] text-ink-muted">
      If you’d rather skip the form.
    </p>
  </section>
</aside>
