---
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import ContinuousWave from "@components/ContinuousWave.astro";
import TrustBar from "@components/TrustBar.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const trustItems = [
  "Founded 2009",
  "Five surfaces, one workspace",
  "Eight document types ingested",
  "US data residency",
  "SOC 2 in progress",
];
---

<section
  class="relative isolate overflow-hidden bg-surface-dark text-ink-on-dark on-dark min-h-[88vh] flex items-center"
  aria-labelledby="hero-title"
>
  <ContinuousWave tone="on-dark" />

  <Container class="relative z-10 py-24 md:py-32 lg:py-40">
    <div class="max-w-[68rem]">
      <p class="section-eyebrow">Stewardship, automated</p>

      <h1
        id="hero-title"
        class="font-display font-normal text-balance leading-[1.04] tracking-[-0.01em] text-ink-on-dark text-[clamp(3rem,7.6vw,5.75rem)]"
        style='font-variation-settings: "opsz" 144;'
      >
        The estate-planning platform built by the firm that wrote the playbook.
      </h1>

      <p class="mt-8 max-w-[44rem] text-[clamp(1.0625rem,1.35vw,1.25rem)] leading-[1.55] text-ink-muted-on-dark text-pretty">
        Heritage Vault collapses 20 to 40 hours of manual estate-plan production into under two. Built for the firms that serve ultra-high-net-worth families.
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-4">
        <Button href={`${base}/request-access/`} variant="on-dark" size="lg" arrow>
          Request access
        </Button>
        <Button href={`${base}/product/`} variant="ghost-on-dark" size="lg" arrow>
          Tour the product
        </Button>
      </div>

      <div class="mt-16 md:mt-20 pt-8 border-t border-rule-dark">
        <TrustBar items={trustItems} onDark align="left" />
      </div>
    </div>
  </Container>
</section>
