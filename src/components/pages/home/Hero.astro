---
/**
 * Home hero — direct port of the heritage-brand demo hero.
 * Dark radial-gradient ground, continuous-wave atmosphere, left-aligned content
 * inside an 880px max-width column. Trust bar lives in a separate white band
 * directly below the hero (per the brand-demo rhythm).
 */
import ContinuousWave from "@components/ContinuousWave.astro";
import Button from "@components/Button.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const trustItems = [
  "Custodian / Trustee",
  "Source Serif 4 + Inter",
  "Cool near-white, deep navy",
  "Continuous flowing wave",
];
---

<section
  class="hero relative isolate overflow-hidden text-white on-dark"
  style="background: radial-gradient(ellipse 80% 60% at 50% 38%, #1B3358 0%, #0F1E36 55%, #08121F 100%); padding: clamp(112px, 14vw, 184px) 0;"
  aria-labelledby="hero-title"
>
  <ContinuousWave tone="on-dark" />

  <div class="relative z-10 w-full mx-auto px-6 sm:px-10 lg:px-14" style="max-width: 1180px;">
    <div style="max-width: 880px;">
      <p
        class="font-sans font-medium uppercase text-ink-muted-on-dark"
        style="font-size: 12px; letter-spacing: 0.18em; margin: 0 0 28px 0;"
      >
        Heritage Vault · Estate Planning Platform
      </p>

      <h1
        id="hero-title"
        class="font-display font-normal text-white text-balance"
        style='font-variation-settings: "opsz" 60; font-size: clamp(48px, 7vw, 80px); line-height: 1.04; letter-spacing: -0.015em; margin: 0 0 32px 0;'
      >
        The estate-planning platform built by the firm that wrote the playbook.
      </h1>

      <p
        class="font-sans text-white text-pretty"
        style="font-size: clamp(17px, 1.6vw, 19px); line-height: 1.65; opacity: 0.85; max-width: 620px; margin: 0 0 48px 0;"
      >
        Heritage Vault collapses 20 to 40 hours of manual estate-plan production into under two. Built on the Approach Book methodology Heritage Strategies has produced by hand since 2009, with source-linked extraction and a branded deliverable for every firm.
      </p>

      <div class="flex flex-wrap gap-3">
        <Button href={`${base}/request-access/`} variant="on-dark">
          Request access
        </Button>
        <Button href={`${base}/product/`} variant="on-dark-secondary">
          Tour the product
        </Button>
      </div>
    </div>
  </div>
</section>

{/* Trust band — white background, centered credentials with bronze dot separators (per brand demo) */}
<div class="bg-surface-card border-y border-rule">
  <div class="mx-auto px-6 sm:px-10 lg:px-14 py-7" style="max-width: 1180px;">
    <ul class="flex flex-wrap items-center justify-center gap-y-3" style="column-gap: 48px;">
      {trustItems.map((item, idx) => (
        <li class="flex items-center gap-x-3 whitespace-nowrap">
          <span class="font-sans uppercase text-ink-muted" style="font-size: 12px; font-weight: 500; letter-spacing: 0.12em;">
            {item}
          </span>
          {idx < trustItems.length - 1 && (
            <span aria-hidden="true" class="hidden md:inline-block rounded-full bg-bronze opacity-70" style="width: 4px; height: 4px;"></span>
          )}
        </li>
      ))}
    </ul>
  </div>
</div>
