---
/**
 * Wealth.com-style recognition strip, now a real marquee.
 * Two duplicated rows of oval cards drift left infinitely. Animation pauses on
 * hover and is disabled entirely under `prefers-reduced-motion`.
 *
 * Specifics are grounded in real Heritage Strategies origin (per brief §4).
 * Industry-award particulars remain placeholders until Heritage AI supplies copy.
 */

type Oval =
  | { kind: "year"; year: string; line: string; tag: string }
  | { kind: "backed"; line: string; partner: string };

const ovals: Oval[] = [
  {
    kind: "year",
    year: "2009",
    line: "Built on the Approach Book methodology used in production since",
    tag: "ORIGIN",
  },
  {
    kind: "backed",
    line: "BACKED BY",
    partner: "Heritage Strategies LLC",
  },
  {
    kind: "year",
    year: "15+ YRS",
    line: "Refined inside a New York multi-family-office practice",
    tag: "FOR FIRMS",
  },
  {
    kind: "backed",
    line: "BUILT WITH",
    partner: "Heritage's senior partners",
  },
  {
    kind: "year",
    year: "8 TYPES",
    line: "Eight estate-planning document types ingested end to end",
    tag: "PLATFORM",
  },
  {
    kind: "backed",
    line: "GROUNDED IN",
    partner: "Thousands of UHNW engagements",
  },
];

// Duplicate the ovals so the marquee loops seamlessly when the first set ends.
const looped = [...ovals, ...ovals];
---

<!-- placeholder: specific industry awards to be supplied by Heritage AI per brief §11 -->
<section
  class="bg-surface-muted py-10 md:py-14 border-y border-rule overflow-hidden"
  aria-label="Recognition and partners"
>
  <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12">
    <div class="flex items-start justify-between gap-6 mb-8 md:mb-10">
      <p class="eyebrow">Provenance</p>
      <p class="hidden sm:block text-[12px] text-ink-muted max-w-xs text-right">
        A platform that arrived with a track record.
      </p>
    </div>
  </div>

  <div class="marquee-track relative overflow-hidden" role="region" aria-roledescription="marquee">
    <ul class="marquee flex items-stretch gap-4 md:gap-5 will-change-transform" aria-hidden="false" role="list">
      {looped.map((oval, idx) => (
        <li class="shrink-0" aria-hidden={idx >= ovals.length ? "true" : undefined}>
          {oval.kind === "year" ? (
            <div
              class="flex items-center gap-4 rounded-full border border-surface-navy/30 bg-surface-card px-5 md:px-6 py-3 md:py-3.5"
            >
              <span
                class="font-display text-[1.5rem] md:text-[1.75rem] leading-none text-surface-navy shrink-0 pr-4 border-r border-rule"
                style='font-variation-settings: "opsz" 60;'
                data-figures="tabular"
              >
                {oval.year}
              </span>
              <span class="text-[12px] md:text-[12.5px] text-ink leading-snug pr-2 whitespace-nowrap">
                {oval.line}
              </span>
              <span class="ml-auto pl-3 border-l border-rule eyebrow text-[10px] shrink-0 whitespace-nowrap">
                {oval.tag}
              </span>
            </div>
          ) : (
            <div
              class="flex items-center gap-3 rounded-full bg-surface-navy text-ink-on-dark px-5 md:px-6 py-3 md:py-3.5"
            >
              <span class="text-[10px] md:text-[10.5px] font-medium tracking-[0.22em] uppercase text-[hsl(35_26%_64%)] shrink-0 whitespace-nowrap">
                {oval.line}
              </span>
              <span class="text-[12.5px] md:text-[13px] leading-snug font-medium text-ink-on-dark whitespace-nowrap">
                {oval.partner}
              </span>
            </div>
          )}
        </li>
      ))}
    </ul>
    <!-- soft edge fades so the marquee never feels cut off -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-surface-muted to-transparent"></div>
    <div aria-hidden="true" class="pointer-events-none absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-surface-muted to-transparent"></div>
  </div>
</section>

<style>
  .marquee {
    animation: marquee-flow 56s linear infinite;
    /* The duplicated track is 2× width; -50% returns to a visually identical state. */
    width: max-content;
  }
  .marquee-track:hover .marquee {
    animation-play-state: paused;
  }
  @keyframes marquee-flow {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(-50%, 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee { animation: none; }
  }
</style>
