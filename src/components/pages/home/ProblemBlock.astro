---
import Section from "@components/Section.astro";
import Button from "@components/Button.astro";
import VideoCard from "@components/VideoCard.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Section background="dark" width="wide" padding="loose" id="the-problem">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    <div class="lg:col-span-5">
      <p class="section-eyebrow">The problem</p>

      <h2
        class="font-display text-balance text-[clamp(2rem,3.8vw,3.25rem)] leading-[1.08] tracking-[-0.005em] text-ink-on-dark"
        style='font-variation-settings: "opsz" 144;'
      >
        Estate plans built in spreadsheets, slide decks, and Word.
      </h2>

      <div class="mt-8 space-y-5 max-w-prose text-[1.0625rem] leading-[1.65] text-ink-muted-on-dark">
        <p>
          20 to 40 hours of manual data entry per client. Trust diagrams hand-built in PowerPoint. Asset values copy-pasted from PDFs.
        </p>
        <p>
          Version confusion across email threads. The work is technical, the workflow is not.
        </p>
      </div>

      <div class="mt-10">
        <Button href={`${base}/product/`} variant="on-dark" arrow>
          See how Vault builds them
        </Button>
      </div>
    </div>

    <div class="lg:col-span-7">
      <VideoCard
        posterId="photo-1497366216548-37526070297c"
        title="Heritage Vault in 90 seconds"
        caption="From upload to deliverable, end to end."
        aspect="landscape"
      />
    </div>
  </div>
</Section>
