---
/**
 * One of the six security-claim sections. Alternating two-column layout,
 * alternating background per order index. Reads like a compliance memo,
 * not a marketing page.
 */
import Container from "@components/Container.astro";

export interface Props {
  order: number;
  total: number;
  title: string;
  summary: string;
  bullets: string[];
}

const { order, total, title, summary, bullets } = Astro.props;

// Even-index (1, 3, 5) = page; odd-index (2, 4, 6) = card.
// No two adjacent sections share a background.
const isCard = order % 2 === 0;
const bgClass = isCard ? "bg-surface-card text-ink" : "bg-surface-page text-ink";

// Alternate side per section: odd order = title left, bullets right;
// even order = title right, bullets left.
const titleOnLeft = order % 2 === 1;

const pad = (n: number) => String(n).padStart(2, "0");
const claimLabel = `Claim ${pad(order)} / ${pad(total)}`;
---

<section
  class:list={["scroll-mt-24 py-20 md:py-28", bgClass]}
  aria-labelledby={`claim-${order}-title`}
>
  <Container width="default">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 lg:gap-x-16 items-start">
      {/* Title column */}
      <div
        class:list={[
          "lg:col-span-5",
          titleOnLeft ? "lg:order-1" : "lg:order-2 lg:col-start-8",
        ]}
      >
        <p
          class="font-mono text-[12px] tracking-[0.18em] uppercase text-bronze mb-6"
          data-figures="tabular"
        >
          {claimLabel}
        </p>
        <h2
          id={`claim-${order}-title`}
          class="font-display font-normal text-display-md leading-[1.1] tracking-[-0.005em] text-surface-navy text-balance"
          style='font-variation-settings: "opsz" 144;'
        >
          {title}
        </h2>
        <p class="mt-6 text-[17px] md:text-[18px] leading-[1.6] text-ink-muted text-pretty">
          {summary}
        </p>
      </div>

      {/* Bullets column */}
      <div
        class:list={[
          "lg:col-span-6",
          titleOnLeft ? "lg:order-2 lg:col-start-7" : "lg:order-1 lg:col-start-1",
        ]}
      >
        <ul role="list" class="space-y-5">
          {bullets.map((bullet) => (
            <li class="relative flex gap-4 text-[15px] md:text-[15.5px] leading-[1.6]">
              <span
                aria-hidden="true"
                class="select-none mt-[1px] font-mono text-[14px] leading-none text-bronze shrink-0"
              >
                +
              </span>
              <span class="text-ink">{bullet}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</section>
