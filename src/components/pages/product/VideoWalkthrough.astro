---
/**
 * Video walkthrough card — centered, Wealth.com pattern.
 */
import Container from "@components/Container.astro";
import VideoCard from "@components/VideoCard.astro";
---

<section class="bg-surface-card py-24 md:py-32" aria-labelledby="walkthrough-title">
  <Container width="default">
    <div class="max-w-screen-prose mx-auto text-center">
      <p class="section-eyebrow text-center">A guided tour</p>
      <h2
        id="walkthrough-title"
        class="font-display font-normal text-display-md text-surface-navy leading-[1.1] tracking-[-0.005em] text-balance"
        style='font-variation-settings: "opsz" 144;'
      >
        Watch a full engagement in twelve minutes.
      </h2>
      <p class="mt-4 text-[17px] md:text-[18px] leading-[1.6] text-ink-muted text-pretty">
        A real (anonymized) client, walked end to end. Real-time scenarios, source-linked values, branded output.
      </p>
    </div>

    <div class="mt-14 md:mt-16 max-w-screen-prose mx-auto">
      <VideoCard
        posterId="photo-1497366216548-37526070297c"
        title="A full Heritage Vault engagement, end to end"
        caption="Twelve minutes, with a real (anonymized) client."
        aspect="wide"
      />
    </div>
  </Container>
</section>
