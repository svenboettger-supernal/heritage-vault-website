---
/**
 * Product page hero — editorial, light, NOT a navy panel.
 * Asymmetric Source Serif 4 display headline, quiet subhead, centered overview screenshot.
 * Per brief §7.2 + brand prompt: page-led product hero may use the cool near-white ground
 * when the page that follows is a product-led editorial walk-through (this one is).
 */
import Container from "@components/Container.astro";
import PlaceholderScreenshot from "@components/PlaceholderScreenshot.astro";
---

<section class="bg-surface-page pt-16 md:pt-24 lg:pt-32 pb-20 md:pb-28">
  <Container width="default">
    {/* Asymmetric editorial header — text occupies the left ~10 columns */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-6 lg:gap-x-12">
      <div class="lg:col-span-10 lg:col-start-1">
        <p class="section-eyebrow">Product</p>
        <h1
          class="font-display font-normal text-display-xl text-surface-navy leading-[1.04] tracking-[-0.005em] text-balance"
          style='font-variation-settings: "opsz" 144;'
        >
          The five surfaces of an estate plan, now in one workspace.
        </h1>
      </div>
      <div class="lg:col-span-7 lg:col-start-1">
        <p class="mt-6 lg:mt-8 text-[19px] md:text-[21px] leading-[1.55] text-ink-muted text-pretty">
          Walk the product end to end. Upload, extract, review, build, deliver.
        </p>
      </div>
    </div>

    {/* Wide overview screenshot, centered with generous padding */}
    <div class="mt-16 md:mt-20 lg:mt-24">
      <PlaceholderScreenshot
        label="Heritage Vault overview"
        caption="Asset Schedule, Flow Diagram, Estate Distribution Chart in one view"
        aspect="wide"
      />
    </div>
  </Container>
</section>
