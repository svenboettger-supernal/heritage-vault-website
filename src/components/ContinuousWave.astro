---
/**
 * Heritage's signature continuous-wave motion ornament.
 *
 * Direct port of the hero wave from svenboettger-supernal/heritage-brand.
 * Two soft fill waves under two thin glowing sweep arcs, all drifting
 * left at different speeds for an "always alive" atmosphere.
 *
 * Per brand prompt: never as a single stroked line, never in body sections,
 * always respects prefers-reduced-motion.
 */
export interface Props {
  tone?: "on-dark" | "on-light";
  class?: string;
}
const { tone = "on-dark", class: className = "" } = Astro.props;
---

<div class:list={["wave-bg absolute inset-0 overflow-hidden pointer-events-none z-0", className]} aria-hidden="true">
  <svg viewBox="0 0 1440 600" preserveAspectRatio="none" role="presentation" class="w-full h-full block">
    <defs>
      <linearGradient id="hv-waveDeep" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color={tone === "on-dark" ? "#5A7BAA" : "#1E3A5F"} stop-opacity="0" />
        <stop offset="100%" stop-color={tone === "on-dark" ? "#5A7BAA" : "#1E3A5F"} stop-opacity={tone === "on-dark" ? "0.45" : "0.20"} />
      </linearGradient>
      <linearGradient id="hv-sweepBright" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color={tone === "on-dark" ? "#E6EDF5" : "#1E3A5F"} stop-opacity="0" />
        <stop offset="50%" stop-color={tone === "on-dark" ? "#E6EDF5" : "#1E3A5F"} stop-opacity={tone === "on-dark" ? "0.55" : "0.25"} />
        <stop offset="100%" stop-color={tone === "on-dark" ? "#E6EDF5" : "#1E3A5F"} stop-opacity="0" />
      </linearGradient>
      <linearGradient id="hv-sweepSoft" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color={tone === "on-dark" ? "#B8C8DE" : "#1E3A5F"} stop-opacity="0" />
        <stop offset="50%" stop-color={tone === "on-dark" ? "#B8C8DE" : "#1E3A5F"} stop-opacity={tone === "on-dark" ? "0.35" : "0.15"} />
        <stop offset="100%" stop-color={tone === "on-dark" ? "#B8C8DE" : "#1E3A5F"} stop-opacity="0" />
      </linearGradient>
      <filter id="hv-waveSoft" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="18" />
      </filter>
      <filter id="hv-sweepGlow" x="-10%" y="-10%" width="120%" height="120%">
        <feGaussianBlur stdDeviation="2.5" />
      </filter>
    </defs>
    <g filter="url(#hv-waveSoft)">
      <path
        class="wave wave--a"
        d="M-1440,340 C-1080,300 -720,380 -360,340 C0,300 360,380 720,340 C1080,300 1440,380 1800,340 C2160,300 2520,380 2880,340 L2880,600 L-1440,600 Z"
        fill="url(#hv-waveDeep)"
        opacity="0.85"
      />
      <path
        class="wave wave--b"
        d="M-1440,420 C-1080,380 -720,460 -360,420 C0,380 360,460 720,420 C1080,380 1440,460 1800,420 C2160,380 2520,460 2880,420 L2880,600 L-1440,600 Z"
        fill="url(#hv-waveDeep)"
        opacity="0.55"
      />
    </g>
    <g filter="url(#hv-sweepGlow)">
      <path
        class="wave wave--sweep"
        d="M-1440,330 Q-720,210 0,300 T1440,290 T2880,310"
        fill="none"
        stroke="url(#hv-sweepBright)"
        stroke-width="1.6"
        stroke-linecap="round"
      />
      <path
        class="wave wave--sweep-2"
        d="M-1440,390 Q-720,290 0,370 T1440,360 T2880,380"
        fill="none"
        stroke="url(#hv-sweepSoft)"
        stroke-width="1.2"
        stroke-linecap="round"
      />
    </g>
  </svg>
</div>

<style>
  .wave {
    animation: wave-flow linear infinite;
    transform-origin: 0 0;
    will-change: transform;
  }
  .wave--a       { animation-duration: 30s; }
  .wave--b       { animation-duration: 46s; animation-direction: reverse; }
  .wave--sweep   { animation-duration: 22s; }
  .wave--sweep-2 { animation-duration: 38s; animation-direction: reverse; }
  @keyframes wave-flow {
    0%   { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-720px, 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wave { animation: none; }
  }
</style>
