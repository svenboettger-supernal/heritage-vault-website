---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Heading from "@components/Heading.astro";
import Prose from "@components/Prose.astro";
import Hairline from "@components/Hairline.astro";
---

<Layout
  title="Privacy Policy"
  description="How Heritage Vault handles client and visitor data."
  pathname="/privacy/"
>
  <Section width="prose" padding="loose">
    <header class="mb-16">
      <Eyebrow class="mb-6">LEGAL</Eyebrow>
      <Heading size="display-md" as="h1">Privacy Policy</Heading>
      <p
        class="mt-6 font-sans text-[12px] text-ink-muted"
        style="font-variant-numeric: tabular-nums; font-feature-settings: 'tnum' 1;"
      >
        Effective: 2026-06-03 (placeholder, pending counsel review)
      </p>
    </header>

    <Prose>
      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Opening statement</h2>
      <p>
        Heritage Vault takes the protection of personal and client data seriously and is committed to handling it according to fiduciary norms expected of any vendor serving HNW firms.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Data we collect</h2>
      <p>
        Inquiry data submitted via Request Access (name, firm, role, AUM band, message). Site usage analytics if a partner firm enables them; no third-party analytics by default.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>How we use it</h2>
      <p>
        Solely to respond to inquiries, schedule conversations, and provide pilot onboarding. Never sold, never shared.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>How we store it</h2>
      <p>
        US-region encrypted storage, AES-256 at rest, TLS 1.3 in transit. Per-tenant isolation for licensed firms.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Retention</h2>
      <p>
        Inquiry data held for 24 months unless the inquirer requests earlier deletion. Pilot and licensed-firm data per the firm's contract.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Subprocessors</h2>
      <p>
        A current list of subprocessors is maintained and disclosed to every licensed firm.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Cookies</h2>
      <p>
        No third-party analytics or ad cookies. Essential session cookies only.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Your rights</h2>
      <p>
        Inquirers may request access, correction, or deletion of their data at any time by emailing
        {" "}<a href="mailto:privacy@heritagevault.com">privacy@heritagevault.com</a>.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Changes</h2>
      <p>
        Heritage Vault reserves the right to update this policy as the product evolves; material changes will be communicated to active firms.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <!-- placeholder: contact address to be provisioned -->
      <h2>Privacy contact</h2>
      <p>
        <a href="mailto:privacy@heritagevault.com">privacy@heritagevault.com</a>
      </p>
    </Prose>

    <Hairline kind="warm-rule" class="my-12" />

    <aside
      class="card-surface p-6 md:p-8"
      aria-label="Counsel review note"
    >
      <p class="eyebrow mb-3">Counsel review</p>
      <p class="text-[15px] leading-[1.6] text-ink">
        This policy is being finalized by Heritage Vault's counsel. The binding version will appear here once approved.
      </p>
    </aside>
  </Section>
</Layout>
