---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Heading from "@components/Heading.astro";
import Prose from "@components/Prose.astro";
import Hairline from "@components/Hairline.astro";
---

<Layout
  title="Terms of Service"
  description="Heritage Vault terms of service."
  pathname="/terms/"
>
  <Section width="prose" padding="loose">
    <header class="mb-16">
      <Eyebrow class="mb-6">LEGAL</Eyebrow>
      <Heading size="display-md" as="h1">Terms of Service</Heading>
      <p
        class="mt-6 font-sans text-[12px] text-ink-muted"
        style="font-variant-numeric: tabular-nums; font-feature-settings: 'tnum' 1;"
      >
        Effective: 2026-06-03 (placeholder).
      </p>
    </header>

    <Prose>
      <p>
        These Terms of Service govern visitor use of heritagevault.com. They are being finalized by Heritage Vault's counsel; the placeholder below outlines the scope. The binding version will appear here once approved.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Acceptance</h2>
      <p>
        By using the site, the visitor agrees to these terms.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Use of the website</h2>
      <p>
        Informational only; not legal, tax, or fiduciary advice; not an offer to license the product.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Intellectual property</h2>
      <p>
        Content is property of Heritage Strategies LLC and its affiliates.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>No advice via the website</h2>
      <p>
        The site is not a substitute for engaging Heritage Vault under a licensing agreement.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Linking</h2>
      <p>
        Third-party links provided as convenience; Heritage Vault does not endorse external content.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Disclaimer</h2>
      <p>
        Site provided "as is" without warranty of any kind, to the extent permitted by law.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Limitation of liability</h2>
      <p>
        Placeholder, counsel to draft.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Governing law</h2>
      <p>
        Placeholder, defaults to New York pending counsel.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Changes</h2>
      <p>
        Heritage Vault reserves the right to update these terms.
      </p>

      <!-- placeholder: subject to counsel approval per brief §10 -->
      <h2>Contact</h2>
      <p>
        <a href="mailto:legal@heritagevault.com">legal@heritagevault.com</a> (placeholder).
      </p>
    </Prose>

    <Hairline kind="warm-rule" class="my-12" />

    <aside
      class="card-surface p-6 md:p-8"
      aria-label="Counsel review note"
    >
      <p class="eyebrow mb-3">Counsel review</p>
      <p class="text-[15px] leading-[1.6] text-ink">
        Counsel-drafted version forthcoming.
      </p>
    </aside>
  </Section>
</Layout>
