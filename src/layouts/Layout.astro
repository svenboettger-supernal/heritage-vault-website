---
import "@styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Head from "@components/Head.astro";
import Hairline from "@components/Hairline.astro";

export interface Props {
  title: string;
  description: string;
  pathname?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  pathname = "/",
  showHeader = true,
  showFooter = true,
  ogImage,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <Head
    title={title}
    description={description}
    pathname={pathname}
    ogImage={ogImage}
    jsonLd={jsonLd}
  />
  <body class="bg-surface-page text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:bg-surface-card focus:px-3 focus:py-2 focus:text-ink focus:rounded focus:border focus:border-rule"
    >
      Skip to content
    </a>

    {showHeader && <Header pathname={pathname} />}
    <Hairline kind="bronze" />

    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>

    {showFooter && (
      <>
        <Hairline kind="bronze" />
        <Footer />
      </>
    )}
  </body>
</html>
